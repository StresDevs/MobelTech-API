# Environment
NODE_ENV=development
PORT=3001

# Neon Database
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/mobeltech?sslmode=require

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins (use "*" to allow all, not recommended in prod)
CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app
